FRONTEND_PORT=5173
BACKEND_PORT=4000
# PM2 cluster instances for production (`max` uses all available CPU cores).
PM2_INSTANCES=max

CLIENT_ORIGIN=http://localhost:5173
VITE_API_PROXY_TARGET=http://localhost:4000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=loadpulse
# Optional MongoDB TLS settings (recommended in production/cloud databases).
MONGODB_TLS=false
MONGODB_TLS_CA_FILE=
MONGODB_TLS_ALLOW_INVALID_CERTS=false
# Optional Redis cache (set REDIS_URL to enable caching).
REDIS_URL=
# Docker-only Redis URL (used by docker-compose service-to-service networking).
DOCKER_REDIS_URL=redis://redis:6379
REDIS_DEFAULT_TTL_SECONDS=30
MONGO_PORT=27018

# Optional: if empty, server generates a temporary secret on startup.
AUTH_JWT_SECRET=
# Field-level encryption key used to protect sensitive DB fields at rest.
# Required in production. Use a long random value (32+ chars).
DATA_ENCRYPTION_KEY=
# Optional comma-separated prior keys for key rotation reads.
DATA_ENCRYPTION_LEGACY_KEYS=
# Optional GitHub OAuth login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
MAX_SERIES_POINTS=180
MAX_PERCENTILE_SAMPLES=5000
