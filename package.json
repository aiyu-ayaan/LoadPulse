{
  "name": "loadpulse",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "tsc -b && vite build",
