    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.6",
    "mongoose": "^8.19.3",
    "node-cron": "^4.2.1",
    "pm2": "^5.4.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
